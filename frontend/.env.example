# OPMarket — Environment Variables
# Copy to .env and fill in your deployed contract addresses.

# NFT Marketplace contract address (opt1... format)
VITE_MARKETPLACE_CONTRACT=

# NFT Launchpad contract address (opt1... format)
VITE_LAUNCHPAD_CONTRACT=

# BaseNFT collection address (opt1... format)
VITE_BASE_NFT_CONTRACT=

# HODL payment token address (defaults to utilisBTC if unset)
VITE_HODL_TOKEN_CONTRACT=opt1sqrpxenjta0hgpdzr32jc6gucr3llwv6scvn0p5ha
